{
  "name": "@uniformdev/component-starter-kit",
  "version": "7.0.0",
  "private": true,
  "engines": {
    "yarn": "please-use-npm",
    "pnpm": "please-use-npm",
    "node": "^18.18.0 || ^19.8.0 || >= 20.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "run-s pull:dex apply:dex pull:locales next:dev",
    "build": "run-s pull:locales pull:dex apply:dex next:build",
    "start": "next start",
    "dev:watch": "cross-env WATCH=true run-s pull:dex apply:dex next:dev",
    "next:dev": "next dev",
    "next:build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "init": "csk-cli init",
    "component:extract": "csk-components extract",
    "component:scaffold": "csk-cli scaffold",
    "pull:dex": "design-extensions-tools pull",
    "apply:dex": "design-extensions-tools apply",
    "push:dex": "design-extensions-tools push",
    "pull:locales": "csk-cli pull -l",
    "pull:content": "uniform sync pull --config ./uniform.config.core.ts",
    "push:content": "uniform sync push --config ./uniform.config.core.ts",
    "pull:content:full": "uniform sync pull --config ./uniform.config.full.ts",
    "push:content:full": "uniform sync push --config ./uniform.config.full.ts",
    "pull:content:dev": "uniform sync pull --config ./uniform.config.dev.ts",
    "push:content:dev": "uniform sync push --config ./uniform.config.dev.ts",
    "uniform:pull": "csk-cli pull -u",
    "uniform:push": "run-s push:dex push:content",
    "uniform:publish": "uniform context manifest publish"
  },
  "dependencies": {
    "@uniformdev/assets": "^20.63.0",
    "@uniformdev/canvas": "^20.63.0",
    "@uniformdev/csk-components": "^6.1.63-alpha.1",
    "@uniformdev/design-extensions-tools": "^6.1.63-alpha.1",
    "@uniformdev/next-app-router": "^20.63.0",
    "@uniformdev/next-app-router-client": "^20.63.0",
    "@uniformdev/next-app-router-shared": "^20.63.0",
    "js-cookie": "^3.0.5",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@uniformdev/cli": "^20.63.0",
    "@uniformdev/csk-cli": "^6.1.63-alpha.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.31.0",
    "eslint-config-next": "^16.1.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.7.3"
  }
}
